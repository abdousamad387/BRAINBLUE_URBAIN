# Pylint configuration for BRAINBLUE URBAIN

[MASTER]
jobs=4
persistent=yes
load-plugins=
    pylint.extensions.docparams,
    pylint.extensions.typing,
unsafe-load-all-extensions=no
extension-pkg-allow-list=
extension-pkg-whitelist=cv2,numpy

[MESSAGES CONTROL]
disable=
    # Disable some checks that are too strict or less useful
    missing-docstring,
    too-few-public-methods,
    duplicate-code,
    too-many-arguments,
    too-many-instance-attributes,
    too-many-branches,
    no-member,
    line-too-long,
    # Disable these for now, but can be enabled later
    fixme,
    protected-access,

[REPORTS]
output-format=colorized
reports=no
score=yes

[FORMAT]
max-line-length=100
indent-string='    '
indent-after-paren=4
max-locals=15
max-branches=12
max-attributes=7

[LOGGING]
logging-format-style=new
logging-modules=logging

[VARIABLES]
init-import=no
dummy-variables-rgx=_+$|^ignored_|^unused_

[CLASSES]
defining-attr-methods=__init__,__new__,setUp,__post_init__

[DESIGN]
max-args=5
max-attributes=7
max-bool-expr=5
max-branches=12
max-locals=15
max-parents=7
max-public-methods=20
max-returns=6
max-statements=50
min-public-methods=2

[TYPECHECK]
contextmanager-decorators=contextlib.contextmanager
ignored-argument-names=_.*|^ignored_|^unused_

[BASIC]
good-names=i,j,k,ex,Run,_
bad-names=foo,bar,baz,toto,tutu,tata

[SPELLING]
# Spelling dictionary location
spelling-dict=en_US
# Comment the following line to enable checking the spelling of
# comments and docstrings
spelling-ignore-comments=yes
spelling-ignore-words=

[SIMILARITIES]
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes
