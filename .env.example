# BRAINBLUE URBAIN - Configuration Environment

# Environnement (development, staging, production)
ENVIRONMENT=development
FLASK_ENV=development

# Base de données
DATABASE_URL=postgresql://brainblue_user:secure_password_2026@localhost:5432/brainblue_urbain
SQLALCHEMY_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# Sécurité - DOIT ÊTRE CHANGÉ EN PRODUCTION
SECRET_KEY=brainblue-urbain-very-secret-key-change-this
JWT_SECRET_KEY=jwt-brainblue-very-secret-key-change-this

# JWT Configuration
JWT_ACCESS_TOKEN_EXPIRES=86400
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000

# API Configuration
HOST=0.0.0.0
PORT=5000
MAX_CONTENT_LENGTH=52428800

# Mail (pour notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Sentry (Error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/brainblue.log

# ML Models Configuration
MODEL_PATH=./ml_models
SAVED_MODELS_PATH=./ml_models/saved

# Data Management
DATA_DIR=./data
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# External APIs (si utilisés)
GOOGLE_EARTH_ENGINE_CREDENTIAL=./config/earth-engine-key.json
MAPBOX_TOKEN=your-mapbox-token
OPENWEATHER_API_KEY=your-openweather-api-key

# Monitoring
ENABLE_MONITORING=True
ENABLE_PROFILING=False
METRICS_PORT=9090

# Backup Configuration
BACKUP_ENABLED=True
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30

# Feature Flags
ENABLE_AI_PREDICTIONS=True
ENABLE_REAL_TIME_MONITORING=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_ALERTS=False

# Performance Tuning
CONNECTION_POOL_SIZE=10
CONNECTION_POOL_RECYCLE=3600
CACHE_DEFAULT_TIMEOUT=300

# Debug (TOUJOURS False en production)
DEBUG=False
TESTING=False

# Autres configurations
TIMEZONE=Africa/Dakar
LANGUAGE=fr
