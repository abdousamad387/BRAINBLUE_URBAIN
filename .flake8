[flake8]
# Flake8 Configuration for BRAINBLUE URBAIN

# Maximum line length (should match black: 100)
max-line-length = 100

# Exclude specific directories and files
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    .eggs,
    *.egg,
    build,
    dist,
    .tox,
    .pytest_cache,
    .mypy_cache,
    .coverage,
    htmlcov,
    node_modules,
    migrations,
    docs

# Ignore specific error codes
ignore =
    # E203: whitespace before ':'
    E203,
    # W503: line break before binary operator
    W503,
    # W504: line break after binary operator
    W504,
    # E501: line too long (handled by black)
    E501,
    # E266: too many leading '#' for block comment
    E266,

# Complexity settings
max-complexity = 10

# Per-file ignores
per-file-ignores =
    __init__.py:F401,
    backend/migrations/*:E402,
    tests/*:F401,F811,

# Show statistics for violations
statistics = True

# Show source code for violations
show-source = True

# Format output with colors (if available)
color = auto
